{
  "name": "earnhub",
  "version": "1.0.0",
  "description": "EarnHub - Your Gateway to Online Earnings",
  "main": "server.js",
  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),path=require('path'),d=process.env.RAILWAY_VOLUME_MOUNT_PATH||process.env.DATA_DIR||path.join(__dirname,'data');fs.mkdirSync(d,{recursive:true});console.log('💾 Data dir ready:',d);\"",
    "start": "node server.js",
    "build": "echo 'Build complete'"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.6",
    "express": "4.18.2",
    "express-session": "1.17.3",
    "uuid": "9.0.0",
    "@lipana/sdk": "1.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
